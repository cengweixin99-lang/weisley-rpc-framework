{
  "name": "@weisley-rpc/agent-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/start-agents.ts",
    "demo:client": "tsx src/demo-client.ts"
  },
  "dependencies": {
    "@weisley-rpc/agent-contracts": "workspace:*",
    "@weisley-rpc/agent-runtime": "workspace:*"
  }
}